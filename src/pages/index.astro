---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { url } from "../config";
---

<BaseLayout sideBarActiveItemID="home">
    <div class="pb-12 mt-5 space-y-8">

        <!-- ===== Hero 区 ===== -->
        <div class="space-y-2">
            <div class="text-sm font-medium text-ac-primary-dark tracking-wide">你好，欢迎来到 👋</div>
            <div class="text-4xl font-bold leading-tight">沈燕的个人主页</div>
            <div class="text-lg font-medium text-ac-text/70 pt-1">宁波独立室内设计师 · 十年沉淀</div>
        </div>

        <!-- ===== 一句话简介 ===== -->
        <div class="text-base leading-8 text-ac-text/80 space-y-1 max-w-lg">
            <p>坐标宁波，深耕设计行业十年。</p>
            <p>不计较、不内耗，不将就，不套路。</p>
            <p>朋友型设计师，懂你情绪的 INFJ。<span class="text-ac-primary-dark font-semibold">耐心温柔，自带闭环。</span></p>
        </div>

        <!-- ===== 标签 ===== -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <!-- 独立设计师 -->
            <div class="animal-tag animal-tag-teal select-none">
                <span class="animal-tag-icon">🏠</span>
                <div class="animal-tag-body">
                    <span class="animal-tag-title">独立设计师</span>
                    <span class="animal-tag-sub">不依附于装修公司</span>
                </div>
            </div>
            <!-- 十年经验 -->
            <div class="animal-tag animal-tag-peach select-none">
                <span class="animal-tag-icon">📐</span>
                <div class="animal-tag-body">
                    <span class="animal-tag-title">十年经验</span>
                    <span class="animal-tag-sub">专注设计，不走弯路</span>
                </div>
            </div>
            <!-- 极简主义 -->
            <div class="animal-tag animal-tag-blue select-none">
                <span class="animal-tag-icon">🪄</span>
                <div class="animal-tag-body">
                    <span class="animal-tag-title">极简主义</span>
                    <span class="animal-tag-sub">做精不做多</span>
                </div>
            </div>
            <!-- INFJ -->
            <div class="animal-tag animal-tag-pink select-none">
                <span class="animal-tag-icon">🌿</span>
                <div class="animal-tag-body">
                    <span class="animal-tag-title">INFJ</span>
                    <span class="animal-tag-sub">懂你情绪，温柔有闭环</span>
                </div>
            </div>
            <!-- 宁波 · 江浙沪 -->
            <div class="animal-tag animal-tag-green select-none">
                <span class="animal-tag-icon">📍</span>
                <div class="animal-tag-body">
                    <span class="animal-tag-title">宁波 · 江浙沪</span>
                    <span class="animal-tag-sub">本地深度服务</span>
                </div>
            </div>
        </div>

        <style>
            /* ===== Animal Island Tag Cards ===== */
            .animal-tag {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 14px 18px;
                border-radius: 20px;
                box-shadow: 0 4px 10px rgba(107, 92, 67, 0.42);
                transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                            box-shadow 0.2s ease;
                position: relative;
            }

            .animal-tag:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 20px rgba(107, 92, 67, 0.5);
            }

            .animal-tag:active {
                transform: translateY(1px);
                box-shadow: 0 2px 6px rgba(107, 92, 67, 0.35);
                transition-duration: 0.1s;
            }

            .animal-tag-icon {
                font-size: 1.5rem;
                line-height: 1;
                flex-shrink: 0;
            }

            .animal-tag-body {
                display: flex;
                flex-direction: column;
                gap: 1px;
                min-width: 0;
            }

            .animal-tag-title {
                font-size: 0.875rem;
                font-weight: 600;
                line-height: 1.3;
            }

            .animal-tag-sub {
                font-size: 0.7rem;
                font-weight: 400;
                opacity: 0.75;
                line-height: 1.3;
            }

            /* Color variants */
            .animal-tag-teal {
                background: #82d5bb;
                color: #fff;
            }
            .animal-tag-peach {
                background: #f7cd67;
                color: #725d42;
            }
            .animal-tag-blue {
                background: #889df0;
                color: #fff;
            }
            .animal-tag-pink {
                background: #f8a6b2;
                color: #fff;
            }
            .animal-tag-green {
                background: #8ac68a;
                color: #fff;
            }
        </style>

        <div class="divider"></div>

        <!-- ===== 数据亮点 ===== -->
        <div class="grid grid-cols-3 gap-3">
            <div class="stat bg-ac-cream rounded-ac-md p-4 text-center border border-ac-cream-dark shadow-sm">
                <div class="stat-value text-2xl font-bold text-ac-primary-dark">10年</div>
                <div class="stat-desc text-xs mt-1 text-ac-text/60">设计经验</div>
            </div>
            <div class="stat bg-ac-cream rounded-ac-md p-4 text-center border border-ac-cream-dark shadow-sm">
                <div class="stat-value text-2xl font-bold text-ac-primary-dark">3460</div>
                <div class="stat-desc text-xs mt-1 text-ac-text/60">获赞与收藏</div>
            </div>
            <div class="stat bg-ac-cream rounded-ac-md p-4 text-center border border-ac-cream-dark shadow-sm">
                <div class="stat-value text-2xl font-bold text-ac-primary-dark">32+</div>
                <div class="stat-desc text-xs mt-1 text-ac-text/60">设计内容笔记</div>
            </div>
        </div>

        <!-- ===== 精选作品 ===== -->
        <div>
            <div class="text-2xl font-bold mb-4">精选作品</div>

            <!-- 共享茶室 - 跳转小红书 -->
            <a href="https://www.xiaohongshu.com/user/profile/5b19e59be8ac2b261e2f167a" target="_blank" rel="noopener" class="block no-underline group">
                <div class="rounded-ac-xl overflow-hidden mb-3 w-full aspect-[16/9] shadow-sm">
                    <img
                        src={url('images/kitchen.jpg')}
                        alt="共享茶室 · 乐道"
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                    />
                </div>
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h3 class="text-lg font-bold text-base-content group-hover:text-ac-primary-dark transition-colors">共享茶室 · 乐道</h3>
                        <p class="text-sm text-base-content/60 mt-0.5 leading-relaxed">写字楼里的茶室设计。极简与禅意的融合，在高效节奏中开辟一片宁静天地。</p>
                    </div>
                    <span class="badge badge-secondary text-xs shrink-0 mt-1">案例</span>
                </div>
            </a>
            <div class="divider my-3"></div>

            <!-- 中梁叠墅 - 跳转小红书 -->
            <a href="https://www.xiaohongshu.com/user/profile/5b19e59be8ac2b261e2f167a" target="_blank" rel="noopener" class="block no-underline group">
                <div class="rounded-ac-xl overflow-hidden mb-3 w-full aspect-[16/9] shadow-sm">
                    <img
                        src={url('images/diushu.jpg')}
                        alt="中梁首府叠墅"
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                    />
                </div>
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h3 class="text-lg font-bold text-base-content group-hover:text-ac-primary-dark transition-colors">中梁首府叠墅 · 细节满满</h3>
                        <p class="text-sm text-base-content/60 mt-0.5 leading-relaxed">叠墅案例分享，从空间规划到工艺细节，每一处都经过反复推敲。无边框工艺、齐平门套……</p>
                    </div>
                    <span class="badge badge-secondary text-xs shrink-0 mt-1">案例</span>
                </div>
            </a>
            <div class="divider my-3"></div>

            <!-- 厨房指南 - 跳转小红书 -->
            <a href="https://www.xiaohongshu.com/user/profile/5b19e59be8ac2b261e2f167a" target="_blank" rel="noopener" class="block no-underline group">
                <div class="rounded-ac-xl overflow-hidden mb-3 w-full aspect-[16/9] shadow-sm">
                    <img
                        src={url('images/chashi.jpg')}
                        alt="设计师私藏厨房指南"
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                    />
                </div>
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h3 class="text-lg font-bold text-base-content group-hover:text-ac-primary-dark transition-colors">设计师私藏厨房指南</h3>
                        <p class="text-sm text-base-content/60 mt-0.5 leading-relaxed">540赞 · 571收藏。电器视觉整合、边角高效利用、台面合理分区……把生活方式融入厨房细节。</p>
                    </div>
                    <span class="badge badge-secondary text-xs shrink-0 mt-1">干货</span>
                </div>
            </a>
        </div>

        <!-- ===== 行动按钮 ===== -->
        <div class="flex flex-wrap gap-3">
            <a href="https://www.xiaohongshu.com/user/profile/5b19e59be8ac2b261e2f167a" target="_blank" rel="noopener" class="btn bg-ac-primary text-white border-0 hover:bg-ac-primary-dark rounded-ac-md">
                在小红书关注我
            </a>
            <a href={url('personal')} class="btn btn-outline border-ac-primary text-ac-primary-dark hover:bg-ac-sand hover:border-ac-primary hover:text-ac-primary-dark rounded-ac-md">
                了解更多关于我
            </a>
        </div>
    </div>
</BaseLayout>
